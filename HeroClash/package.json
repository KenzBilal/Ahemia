{
  "name": "heroclash",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:metro": "expo start --dev-client --port 8081",
    "android:reverse": "adb reverse tcp:8081 tcp:8081",
    "android:build:debug": "cd android && ./gradlew assembleDebug --no-daemon",
    "android:install:debug": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "android:launch": "adb shell monkey -p com.anonymous.heroclash -c android.intent.category.LAUNCHER 1",
    "android:usb": "npm run android:build:debug && npm run android:install:debug && npm run android:reverse && npm run android:launch",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/native-stack": "^7.14.6",
    "@shopify/react-native-skia": "2.4.18",
    "expo": "~55.0.8",
    "expo-av": "^16.0.8",
    "expo-haptics": "~55.0.9",
    "expo-screen-orientation": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "nanoid": "^5.1.7",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-udp": "^4.1.7",
    "react-native-worklets": "^0.7.4",
    "react-native-zeroconf": "^0.14.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.2",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.12",
    "typescript": "~5.9.2"
  },
  "private": true
}
